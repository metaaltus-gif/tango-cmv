# Copia esse arquivo pra .env.local e preenche com seus valores.
# Tambem cadastra essas mesmas vars no Vercel ao subir.

# URL do projeto Supabase (CMV)
NEXT_PUBLIC_SUPABASE_URL=https://agtyburqgtiyavbmezvg.supabase.co

# === CHAVE NOVA (preferida) ===
# Pega em: Dashboard Supabase > Settings > API > "Publishable and secret API keys"
# Linha "Publishable key" > Copy
# Comeca com sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Qq1CpfPoQe...

# === CHAVE LEGACY (fallback, opcional) ===
# Pega em: Dashboard Supabase > Settings > API > "Legacy anon, service_role API keys"
# Linha "anon public" > Copy
# Comeca com eyJhbGciOi...
# Se voce setar NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY acima, NAO precisa setar essa.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Org_id padrao (Kingdom Sushi Clermont)
NEXT_PUBLIC_DEFAULT_ORG_ID=1
